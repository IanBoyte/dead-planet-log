---
import { getCollection } from 'astro:content';
import TerminalLayout from '../layouts/TerminalLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const logs = await getCollection('logs');
logs.sort((a, b) => parseInt(a.data.entry) - parseInt(b.data.entry));

const latestStatus = logs.at(-1)?.data.status ?? 'NOMINAL';
const statusClass = {
  NOMINAL:  '',
  CAUTION:  'warn',
  WARNING:  'warn',
  CRITICAL: 'crit',
}[latestStatus] ?? '';

const now = new Date();
const dayOfYear = Math.ceil((now.getTime() - new Date(now.getFullYear(), 0, 0).getTime()) / 86400000);
const stardate = `${now.getFullYear()}.${String(dayOfYear).padStart(3,'0')}.${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;

// Fixed-width status badge (11 chars)
const badge: Record<string, string> = {
  NOMINAL:  '[NOMINAL  ]',
  CAUTION:  '[CAUTION  ]',
  WARNING:  '[WARNING  ]',
  CRITICAL: '[CRITICAL ]',
};
---
<TerminalLayout>

  <div class="ship-name">MATRON'S CALL</div>
  <div class="ship-sub">Medium Freighter // Registry 7744-MC // Andromache Drift Route</div>

  <hr class="div" />

  <table class="kv">
    <tr>
      <td class="k">Ship Captain</td>
      <td class="v">Sim Troob (Human)</td>
    </tr>
    <tr>
      <td class="k">Cargo</td>
      <td class="v warn">Sealed — Classification Unknown</td>
    </tr>
    <tr>
      <td class="k">Destination</td>
      <td class="v">Waypoint Theta-9</td>
    </tr>
    <tr>
      <td class="k">Deadline</td>
      <td class="v warn">1 Hyperspace Week</td>
    </tr>
    <tr>
      <td class="k">System Status</td>
      <td class={`v ${statusClass}`}>{latestStatus}</td>
    </tr>
    <tr>
      <td class="k">Local Stardate</td>
      <td class="v">{stardate}</td>
    </tr>
  </table>

  <hr class="div" />

  <div class="prompt">Accessing ship log database...</div>
  <div class="prompt">{logs.length} records found</div>

  <hr class="div" />

  <nav class="log-list">
    {logs.map((log) => {
      const slug = log.id.replace(/\.md$/, '');
      return (
        <a href={`${base}/logs/${slug}`} class="log-row">
          <span class="lr-num">[{log.data.entry}]</span>
          <span class="lr-date">{log.data.stardate}</span>
          <span class={`lr-status ${log.data.status}`}>{badge[log.data.status]}</span>
          <span class="lr-title">{log.data.title}</span>
        </a>
      );
    })}
    <a href={`${base}/crew`} class="log-row log-row-crew">
      <span class="lr-num">[C]</span>
      <span class="lr-date"></span>
      <span class="lr-status lr-status-manifest">[MANIFEST ]</span>
      <span class="lr-title">CREW MANIFEST</span>
    </a>
  </nav>

  <hr class="div" />
  <div class="prompt-input-line" id="input-prompt">
    <span class="pil-label">Select entry:</span>
    <input
      type="text"
      id="entry-input"
      class="term-input"
      autocomplete="off"
      spellcheck="false"
      maxlength="4"
      aria-label="Enter a log entry number or C for crew manifest"
    />
  </div>

</TerminalLayout>

<script>
  const input    = document.getElementById('entry-input') as HTMLInputElement | null;
  const rows     = Array.from(document.querySelectorAll<HTMLAnchorElement>('.log-row'));
  let selectedIdx = -1;

  function setSelected(idx: number) {
    rows.forEach((r, i) => r.classList.toggle('selected', i === idx));
    selectedIdx = idx;
  }

  function navigate() {
    if (selectedIdx >= 0) {
      window.location.href = rows[selectedIdx].href;
      return;
    }
    const num = parseInt(input?.value.trim() ?? '');
    if (!isNaN(num) && num >= 1 && num <= rows.length) {
      window.location.href = rows[num - 1].href;
    }
  }

  input?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      setSelected(Math.min(selectedIdx + 1, rows.length - 1));
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setSelected(Math.max(selectedIdx - 1, 0));
    } else if (e.key === 'Enter') {
      navigate();
    }
  });

  input?.addEventListener('input', () => {
    const val = input.value.trim().toLowerCase();
    if (val === 'c' || val === 'crew') {
      setSelected(rows.length - 1); // crew is always the last row
    } else {
      const num = parseInt(val);
      if (!isNaN(num) && num >= 1 && num <= rows.length) {
        setSelected(num - 1);
      } else {
        setSelected(-1);
      }
    }
  });
</script>
